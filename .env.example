# seoblue0342 운영 환경변수 예시
# 이 파일을 .env로 복사한 뒤 실제 값을 입력합니다. .env는 Git에 커밋하지 않습니다.

# Flask 세션 서명키: 최소 48바이트의 무작위 값 권장
SEO_SESSION_SECRET=
SEO_COOKIE_SECURE=1
SEO_AUTH_DB_PATH=/app/data/auth.db

# 최초 배포에서만 사용할 임시 비밀번호. admin, yesblue0342 계정이 강한 해시로 생성됩니다.
# 두 계정의 최초 비밀번호 변경이 끝나면 .env에서 이 값을 제거하세요.
SEO_INITIAL_PASSWORD=

# Google Drive OAuth (서버 전용, 브라우저에 전달되지 않음)
# OCI 배포 시 값이 비어 있으면 /opt/stella-ai-workspace/.env의 동일 자격증명만
# 안전하게 재사용합니다. Stella의 GOOGLE_OAUTH_* / GOOGLE_DRIVE_* 별칭도 지원합니다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# 실제 OAuth scope가 쓰기를 허용하는 것을 확인한 뒤에만 1로 변경.
# OCI 자동 배포는 전체 scope 검증과 함께 이 값을 1로 강제합니다.
SEO_DRIVE_WRITES_ENABLED=0

# 기존 SEO 분석 API
SERPER_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 기존 자동 분석 스케줄
SEO_SCHEDULE_ENABLED=1
SEO_SCHEDULE_HOUR=4
SEO_SCHEDULE_TZ=Asia/Seoul
